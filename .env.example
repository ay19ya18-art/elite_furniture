# =============================================================================
# Elite Furniture — متغيرات البيئة (انسخ الملف إلى .env للتطوير المحلي)
# =============================================================================

# رابط الـ API على Railway (بدون / في النهاية). اتركه فارغًا لاستخدام التخزين المحلي فقط.
VITE_API_URL=https://your-api.railway.app

# (اختياري) تجاوز بيانات الأدمن الافتراضية — إن لم تضعها يُستخدم الافتراضي من README / الكود.
# VITE_ADMIN_EMAIL=
# VITE_ADMIN_PASSWORD=

# Google Sign-In للعملاء — من Google Cloud Console → APIs & Services → Credentials
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=
